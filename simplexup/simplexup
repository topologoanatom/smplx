#!/usr/bin/env bash
set -eo pipefail

# NOTE: if you make modifications to this script, please increment the version number.
# WARNING: the SemVer pattern: major.minor.patch must be followed as we use it to determine if the script is up to date.
SIMPLEXUP_INSTALLER_VERSION="0.0.4"

BASE_DIR=${XDG_CONFIG_HOME:-$HOME}
SIMPLEX_DIR=${SIMPLEX_DIR:-"$BASE_DIR/.simplex"}
SIMPLEX_VERSIONS_DIR="$SIMPLEX_DIR/versions"
SIMPLEX_BIN_DIR="$SIMPLEX_DIR/bin"
SIMPLEX_BIN_URL="https://raw.githubusercontent.com/BlockstreamResearch/smplx/master/simplexup/simplexup"
SIMPLEX_BIN_PATH="$SIMPLEX_BIN_DIR/simplexup"
SIMPLEXUP_IGNORE_VERIFICATION=false
DEFAULT_SIMPLEX_REPO="BlockstreamResearch/smplx"

DEP_BINS=(elementsd electrs)
BINS=(simplex "${DEP_BINS[@]}")
HASH_NAMES=()
HASH_VALUES=()

main() {
  need_cmd git
  need_cmd curl

  while [[ -n $1 ]]; do
    case $1 in
      --)               shift; break;;

      -v|--version)     shift; version;;
      -C|--commit)      shift; SIMPLEX_COMMIT=$1;;
      -U|--update)      shift; update;;
      -r|--repo)        shift; SIMPLEX_REPO=$1;;
      -i|--install)     shift; SIMPLEX_VERSION=$1;;
      -l|--list)        shift; list;;
      -u|--use)         shift; SIMPLEX_VERSION=$1; use;;
      -f|--force)       SIMPLEXUP_IGNORE_VERIFICATION=true;;
      --arch)           shift; SIMPLEX_ARCH=$1;;
      --platform)       shift; SIMPLEX_PLATFORM=$1;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        warn "unknown option: $1"
        usage
        exit 1
    esac; shift
  done

  # Print the banner after successfully parsing args
  banner

  # Check if the simplexup installer is up to date, warn the user if not
  check_installer_up_to_date

  check_bins_in_use

  # Default to Simplex repo
  SIMPLEX_REPO=${SIMPLEX_REPO:-$DEFAULT_SIMPLEX_REPO}

  # Install by downloading binaries
  LATEST_TAG=$(latest_tag)
  SIMPLEX_VERSION=${SIMPLEX_VERSION:-$LATEST_TAG}

  # Check if the requested version exists
  if [[ "${SIMPLEX_VERSION}" != "${LATEST_TAG}" ]]; then
    validate_tag_version "${SIMPLEX_VERSION}" "${SIMPLEX_REPO}"
  fi

  say "installing simplex (version ${SIMPLEX_VERSION})"

  # Detect platform and architecture.
  detect_platform_arch

  # Compute the URL of the release tarball in the Simplex repository.
  GITHUB_REPO_URL="https://github.com/${SIMPLEX_REPO}"
  RELEASE_URL="${GITHUB_REPO_URL}/releases/download/${SIMPLEX_VERSION}/"
  ATTESTATION_URL="${RELEASE_URL}simplex-${SIMPLEX_VERSION}-${PLATFORM}-${ARCHITECTURE}.attestation.txt"
  BIN_ARCHIVE_URL="${RELEASE_URL}simplex-${SIMPLEX_VERSION}-${PLATFORM}-${ARCHITECTURE}.tar.gz"

  version_dir="${SIMPLEX_VERSIONS_DIR}/${SIMPLEX_VERSION}"
  ensure mkdir -p "$version_dir"

  local BINS_TO_DOWNLOAD=("${BINS[@]}")

  if [[ -n "$SIMPLEX_COMMIT" ]]; then
    local author="$(echo "${SIMPLEX_REPO}" | cut -d'/' -f1 -)"
    BINS_TO_DOWNLOAD=("${DEP_BINS[@]}")

    install_simplex_from_commit "${SIMPLEX_COMMIT}" "${author}" "${GITHUB_REPO_URL}" "${version_dir}"
    say "Successfully compiled simplex from commit: ${SIMPLEX_COMMIT} in repo: ${GITHUB_REPO_URL}"
  fi

  BINS_LIST_UX=$(form_str_list "${BINS_TO_DOWNLOAD[@]}")

  # If `--force` is set, skip the SHA verification.
  if [ "$SIMPLEXUP_IGNORE_VERIFICATION" = false ]; then
    # Check if the version is already installed by downloading the attestation file.
    say "checking if $BINS_LIST_UX for $SIMPLEX_VERSION version are already installed"

    # Create a temporary directory to store the attestation link and artifact.
    tmp_dir="$(mktemp -d 2>/dev/null)" || err "failed to create temp dir"
    tmp="$tmp_dir/attestation.txt"
    ensure download "$ATTESTATION_URL" "$tmp"

    # Read the first line of the attestation file to get the artifact link.
    # The first line should contain the link to the attestation artifact.
    attestation_artifact_link="$(head -n1 "$tmp" | tr -d '\r')"
    attestation_missing=false

    # If the attestation artifact link is empty or the file contains 'Not Found',
    # we consider the attestation missing and skip the SHA verification.
    if [ -z "$attestation_artifact_link" ] || grep -q 'Not Found' "$tmp"; then
      attestation_missing=true
    fi

    # Clean up the temporary attestation file.
    rm -f "$tmp"

    if $attestation_missing; then
      say "no attestation found for this release, skipping SHA verification"
    else
      say "found attestation for $SIMPLEX_VERSION version, downloading attestation artifact, checking..."

      # Download the attestation artifact JSON file.
      tmp="$tmp_dir/simplex-attestation.sigstore.json"
      ensure download "${attestation_artifact_link}/download" "$tmp"

      # Extract the payload from the JSON file.
      payload_b64=$(awk '/"payload":/ {gsub(/[",]/, "", $2); print $2; exit}' "$tmp")
      payload_json=$(printf '%s' "$payload_b64" | base64 -d 2>/dev/null || printf '%s' "$payload_b64" | base64 -D)

      # Extract the names and hashes from the payload JSON.
      # The payload is expected to be a JSON array of objects with "name" and "sha256" fields.
      while read -r name_line && read -r sha_line; do
        name=$(echo "$name_line" | sed -nE 's/.*"name"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/p')
        sha=$(echo "$sha_line" | sed -nE 's/.*"sha256"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/p')

        if [ -n "$name" ] && [ -n "$sha" ]; then
          HASH_NAMES+=("$name")
          HASH_VALUES+=("$sha")
        fi
      done < <(echo "$payload_json" | tr '{}' '\n' | grep -E '"name"|sha256')

      # Clean up the temporary attestation artifact.
      # The hashes are now stored in the HASHES associative array.
      rm -f "$tmp"

      # Check if the binaries are already installed and match the expected hashes.
      # If they do, skip the download.
      all_match=true

      for bin in "${BINS_TO_DOWNLOAD[@]}"; do
        expected=""

        for i in "${!HASH_NAMES[@]}"; do
          if [ "${HASH_NAMES[$i]}" = "$bin" ] || [ "${HASH_NAMES[$i]}" = "$bin.exe" ]; then
            expected="${HASH_VALUES[$i]}"
            break
          fi
        done

        path="$version_dir/$bin"

        if [ -z "$expected" ] || [ ! -x "$path" ]; then
          all_match=false
          break
        fi

        actual=$(compute_sha256 "$path")

        if [ "$actual" != "$expected" ]; then
          all_match=false
          break
        fi
      done

      if $all_match; then
        say "version $SIMPLEX_VERSION already installed and verified (for $BINS_LIST_UX), activating..."
        use
        say "done!"
        exit 0
      fi
    fi

    # If we reach here, we need to download the binaries.
    say "binaries not found or do not match expected hashes, downloading new binaries"
  fi

  # Download and extract the binaries archive
  say "downloading $BINS_LIST_UX for $SIMPLEX_VERSION version"

  tmp_dir="$(mktemp -d 2>/dev/null)" || err "failed to create temp dir"
  tmp_tar="$tmp_dir/simplex.tar.gz"

  ensure download "$BIN_ARCHIVE_URL" "$tmp_tar"
  # Make sure it's a valid tar archive.
  ensure tar tf "$tmp_tar" 1> /dev/null
  ensure tar -C "$tmp_dir" -xvf "$tmp_tar"

  for bin in "${BINS_TO_DOWNLOAD[@]}"; do
    mv "$tmp_dir/$bin" "$version_dir/$bin"
  done
  rm -rf "$tmp_dir"

  if [ "$SIMPLEXUP_IGNORE_VERIFICATION" = true ]; then
    say "skipped SHA verification for downloaded binaries due to --force flag"
  else
    # Verify the downloaded binaries against the attestation file.
    # If the attestation file was not found or is empty, we skip the verification.
    if $attestation_missing; then
      say "no attestation found for these binaries, skipping SHA verification for downloaded binaries"
    else
      say "verifying downloaded binaries against the attestation file"

      failed=false

      for bin in "${BINS_TO_DOWNLOAD[@]}"; do
        expected=""

        for i in "${!HASH_NAMES[@]}"; do
          if [ "${HASH_NAMES[$i]}" = "$bin" ] || [ "${HASH_NAMES[$i]}" = "$bin.exe" ]; then
            expected="${HASH_VALUES[$i]}"
            break
          fi
        done

        path="$SIMPLEX_VERSIONS_DIR/$SIMPLEX_VERSION/$bin"

        if [ -z "$expected" ]; then
          say "no expected hash for $bin"
          failed=true
          continue
        fi

        if [ ! -x "$path" ]; then
          say "binary $bin not found at $path"
          failed=true
          continue
        fi

        actual=$(compute_sha256 "$path")

        if [ "$actual" != "$expected" ]; then
          say "$bin hash verification failed:"
          say "  expected: $expected"
          say "  actual:   $actual"
          failed=true
        else
          say "$bin verified ✓"
        fi
      done

      if $failed; then
        err "one or more binaries failed post-installation verification"
      fi
    fi
  fi

  use

  say "done!"
}

usage() {
  cat 1>&2 <<EOF
The installer for Simplex.

Install, update, and manage Simplex with ease.

By default, the latest stable version is installed from built binaries.

USAGE:
    simplexup <OPTIONS>

OPTIONS:
    -h, --help      Print help information
    -v, --version   Print the version of simplexup
    -C, --commit,   Install specific simplex revision from repository
    -U, --update    Update simplexup to the latest version
    -i, --install   Install a specific version from built binaries
    -l, --list      List versions installed from built binaries
    -u, --use       Use a specific installed version from built binaries
    -r, --repo      Build and install from a remote GitHub repo (uses default branch if no other options are set)
    -f, --force     Skip SHA verification for downloaded binaries (INSECURE - use with caution)
    --arch          Install a specific architecture (supports amd64 and arm64)
    --platform      Install a specific platform (supports linux and darwin)
EOF
}

version() {
  say "$SIMPLEXUP_INSTALLER_VERSION"
  exit 0
}

update() {
  say "updating simplexup..."

  current_version="$SIMPLEXUP_INSTALLER_VERSION"

  # Download the new version.
  tmp_file="$(mktemp)"
  ensure download "$SIMPLEX_BIN_URL" "$tmp_file"

  # Extract new version from downloaded file.
  new_version=$(grep -Eo 'SIMPLEXUP_INSTALLER_VERSION="[0-9]+\.[0-9]+\.[0-9]+"' "$tmp_file" | cut -d'"' -f2)

  # If the new version could not be determined, exit gracefully.
  # This prevents from upgrading to an empty or invalid version.
  if [ -z "$new_version" ]; then
    warn "could not determine new simplexup version. Exiting."
    rm -f "$tmp_file"
    exit 0
  fi

  # If the new version is not greater than the current version, skip the update.
  # This is to prevent downgrades or unnecessary updates.
  if ! version_gt "$new_version" "$current_version"; then
    say "simplexup is already up to date (installed: $current_version, remote: $new_version)."
    rm -f "$tmp_file"
    exit 0
  fi

  # Overwrite existing simplexup
  ensure mv "$tmp_file" "$SIMPLEX_BIN_PATH"
  ensure chmod +x "$SIMPLEX_BIN_PATH"

  say "successfully updated simplexup: $current_version → $new_version"
  exit 0
}

list() {
  if [ -d "$SIMPLEX_VERSIONS_DIR" ]; then
    for VERSION in $SIMPLEX_VERSIONS_DIR/*; do
      say "${VERSION##*/}"

      for bin in "${BINS[@]}"; do
        case $bin in
          simplex)
            bin_path="$VERSION/$bin"
            say "- $(ensure "$bin_path" -V)"
          ;;
        esac
      done

      printf "\n"
    done
  else
    for bin in "${BINS[@]}"; do
      case $bin in
        simplex)
          bin_path="$SIMPLEX_BIN_DIR/$bin"
          say "- $(ensure "$bin_path" -V)"
        ;;
      esac
    done
  fi
  exit 0
}

use() {
  [ -z "$SIMPLEX_VERSION" ] && err "no version provided"

  SIMPLEX_VERSION_DIR="$SIMPLEX_VERSIONS_DIR/$SIMPLEX_VERSION"

  if [ -d "$SIMPLEX_VERSION_DIR" ]; then
    check_bins_in_use
    ensure mkdir -p "$SIMPLEX_BIN_DIR"

    for bin in "${BINS[@]}"; do
      bin_path="$SIMPLEX_BIN_DIR/$bin"
      cp "$SIMPLEX_VERSION_DIR/$bin" "$bin_path"

      # Print usage msg
      case $bin in
        simplex)
          say "- $(ensure "$bin_path" -V)"
        ;;
      esac

      # Check if the default path of the binary is not in SIMPLEX_BIN_DIR
      which_path="$(command -v "$bin" || true)"

      if [ -n "$which_path" ] && [ "$which_path" != "$bin_path" ]; then
        warn ""
        cat 1>&2 <<EOF
There are multiple binaries with the name '$bin' present in your 'PATH'.

This may be the result of installing '$bin' using another method, like Cargo or other package managers.

You may need to run 'rm $which_path' or move '$SIMPLEX_BIN_DIR' in your 'PATH'
to allow the newly installed version to take precedence!

EOF
      fi
    done
    exit 0
  else
    err "version $SIMPLEX_VERSION not installed"
  fi
}

say() {
  printf "simplexup: %s\n" "$1"
}

warn() {
  say "warning: ${1}" >&2
}

err() {
  say "$1" >&2
  exit 1
}

tolower() {
  echo "$1" | awk '{print tolower($0)}'
}

compute_sha256() {
  if check_cmd sha256sum; then
    # Use sed to strip leading backslash (sha256sum on Windows/Git Bash outputs \ prefix for binary files)
    sha256sum "$1" | cut -d' ' -f1 | sed 's/^\\//'
  else
    shasum -a 256 "$1" | awk '{print $1}'
  fi
}

need_cmd() {
  if ! check_cmd "$1"; then
    err "need '$1' (command not found)"
  fi
}

check_cmd() {
  command -v "$1" &>/dev/null
}

latest_tag() {
  # Fetch the latest Simplex release tag name
  LATEST_TAG=$(curl -fsSL "https://api.github.com/repos/$SIMPLEX_REPO/releases/latest" | jq -r .tag_name)

  echo $LATEST_TAG
}

validate_tag_version() {
  local current_version=$1
  local simplex_repo=$2

  say "Checking if version ${current_version} exists..."

  if ! curl -IfsSL "https://github.com/${simplex_repo}/releases/tag/${current_version}" >/dev/null; then
    err "Error: version '${current_version}' not found in ${simplex_repo} releases."
  fi
}

detect_platform_arch() {
  uname_s=$(uname -s)
  PLATFORM=$(tolower "${SIMPLEX_PLATFORM:-$uname_s}")

  case $PLATFORM in
    linux) ;;
    darwin|mac*)
      PLATFORM="darwin"
      ;;
    *)
      err "unsupported platform: $PLATFORM"
      ;;
  esac

  uname_m=$(uname -m)
  ARCHITECTURE=$(tolower "${SIMPLEX_ARCH:-$uname_m}")

  if [ "${ARCHITECTURE}" = "x86_64" ]; then
    # Redirect stderr to /dev/null to avoid printing errors if non Rosetta.
    if [ "$(sysctl -n sysctl.proc_translated 2>/dev/null)" = "1" ]; then
      ARCHITECTURE="arm64" # Rosetta.
    else
      ARCHITECTURE="x86_64" # Intel.
    fi
  elif [ "${ARCHITECTURE}" = "arm64" ] || [ "${ARCHITECTURE}" = "aarch64" ] ; then
    ARCHITECTURE="arm64" # Arm.
  else
    ARCHITECTURE="x86_64" # Amd.
  fi
}

check_installer_up_to_date() {
  say "checking if simplexup is up to date..."

  remote_version=$(curl -fsSL "$SIMPLEX_BIN_URL" | grep -Eo 'SIMPLEXUP_INSTALLER_VERSION="[0-9]+\.[0-9]+\.[0-9]+"' | cut -d'"' -f2)

  if [ -z "$remote_version" ]; then
    warn "Could not determine remote simplexup version. Skipping version check."
    return 0
  fi

  if version_gt "$remote_version" "$SIMPLEXUP_INSTALLER_VERSION"; then
    printf '
Your installation of simplexup is out of date.

Installed: %s → Latest: %s

To update, run:

  simplexup --update

Updating is highly recommended as it gives you access to the latest features and bug fixes.

' "$SIMPLEXUP_INSTALLER_VERSION" "$remote_version" >&2
  else
    say "simplexup is up to date."
  fi
}

# Compares two version strings in the format "major.minor.patch".
# Returns 0 if $1 is greater than $2, 1 if $1 is less than $2, and 1 if they are equal.
#
# Assumes that the version strings are well-formed and contain three numeric components separated by dots.
#
# Example: version_gt "1.2.3" "1.2.4"
#          returns 1 (1.2.3 < 1.2.4)
#          version_gt "1.2.3" "1.2.3"
#          returns 1 (1.2.3 == 1.2.3)
#          version_gt "1.2.4" "1.2.3"
#          returns 0 (1.2.4 > 1.2.3)
version_gt() {
  [ "$1" = "$2" ] && return 1

  IFS=. read -r major1 minor1 patch1 <<EOF
$1
EOF
  IFS=. read -r major2 minor2 patch2 <<EOF
$2
EOF

  [ "$major1" -gt "$major2" ] && return 0
  [ "$major1" -lt "$major2" ] && return 1
  [ "$minor1" -gt "$minor2" ] && return 0
  [ "$minor1" -lt "$minor2" ] && return 1
  [ "$patch1" -gt "$patch2" ] && return 0
  [ "$patch1" -lt "$patch2" ] && return 1

  return 1
}

check_bins_in_use() {
  if check_cmd pgrep; then
    for bin in "${BINS[@]}"; do
      if pgrep -x "$bin" >/dev/null; then
        err "Error: '$bin' is currently running. Please stop the process and try again."
      fi
    done
  else
    warn "Make sure no simplex process is running during the install process!"
  fi
}

# Run a command that should never fail. If the command fails execution
# will immediately terminate with an error showing the failing command.
ensure() {
  if ! "$@"; then err "command failed: $*"; fi
}

# Downloads $1 into $2 or stdout
download() {
  if [ -n "$2" ]; then
    # output into $2
    if check_cmd curl; then
      curl -#o "$2" -L "$1"
    else
      wget --show-progress -qO "$2" "$1"
    fi
  else
    # output to stdout
    if check_cmd curl; then
      curl -#L "$1"
    else
      wget --show-progress -qO- "$1"
    fi
  fi
}

install_simplex_from_commit() {
  local commit=$1
  local author=$2
  local repo_url=$3
  local out_dir=$4

  local simplex_version="simplex-${author}-${commit}"
  local tmp_dir="$(mktemp -d 2>/dev/null)" || err "failed to create temp dir"
  ensure git clone --revision="${commit}" --depth=1 "${repo_url}" "${tmp_dir}"

  say "Installing Simplex version $simplex_version"

  ensure cargo build --release --manifest-path "${tmp_dir}/Cargo.toml"
  ensure mv "${tmp_dir}/target/release/simplex" "${out_dir}/simplex"

  say "Removing temporary directory..."
  rm -rf "${tmp_dir}"
}

# Form a comma separated list with 'and' for user experience
form_str_list() {
  local STR_LIST=("$@")

  local LAST_EL="${STR_LIST[*]: -1}"
  local REST_ELS=("${STR_LIST[@]:0:${#STR_LIST[@]}-1}")
  local EL_STRING=""

  if [ ${#STR_LIST[@]} -eq 1 ]; then
    EL_STRING="${STR_LIST[0]}"
  elif [ ${#STR_LIST[@]} -eq 2 ]; then
    EL_STRING="${STR_LIST[0]} and ${STR_LIST[1]}"
  else
    SAVE_IFS="$IFS"
    IFS=","
    EL_STRING="${REST_ELS[*]}"
    IFS="$SAVE_IFS"

    EL_STRING="${EL_STRING//,/, } and ${LAST_EL}"
  fi

  echo "$EL_STRING"
}

